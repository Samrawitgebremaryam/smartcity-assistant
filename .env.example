# SmartCity Assistant - Environment Template
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT .env TO GITHUB - IT CONTAINS API KEYS!

# ============== REQUIRED ==============
SECRET_KEY=generate-a-secure-key-with-python-secrets-token-hex32
SECRET_KEY_REQUIRED=false

# Get your key from https://aistudio.google.com/app/apikey (free) or https://console.cloud.google.com (paid)
GEMINI_API_KEY=YOUR-GEMINI-API-KEY-HERE

# ============== ENVIRONMENT ==============
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ============== DATABASE (Local) ==============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartcity

# ============== VECTOR DATABASE (Local) ==============
QDRANT_URL=http://localhost:6333

# ============== REDIS (Local) ==============
REDIS_URL=redis://localhost:6379/0

# ============== CORS ==============
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ============== MODEL CONFIGURATION ==============
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4.1-mini

# ============== DATASET ==============
BOOTSTRAP_DATASET_GLOB=ethiopia_smartcity_dataset*.json
ENABLE_DATASET_BOOTSTRAP=true

# ============== RETRIEVAL ==============
RETRIEVAL_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100