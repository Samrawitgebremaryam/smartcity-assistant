PROJECT_NAME=SmartCity RAG Assistant
ENVIRONMENT=production
API_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

POSTGRES_HOST=your-postgres-host.supabase.co
POSTGRES_PORT=65432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=smartcity

QDRANT_URL=https://your-qdrant-cloud.qdrant.tech
REDIS_URL=rediss://redis-cloud.redis.com:6379/0

OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_MODEL=gemini-2.0-flash

UPLOAD_DIR=data/raw/uploads
PROCESSED_DIR=data/processed
SAMPLE_DATA_DIR=data/sample
QDRANT_COLLECTION_NAME=smartcity_documents
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RETRIEVAL_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
OPENAI_MODEL=gpt-4.1-mini
BOOTSTRAP_DATASET_GLOB=ethiopia_smartcity_dataset*.json
ENABLE_DATASET_BOOTSTRAP=true
FALLBACK_SEARCH_BASE_URL=https://www.google.com/search

SECRET_KEY=your-very-long-secret-key-minimum-32-characters
SECRET_KEY_REQUIRED=true
